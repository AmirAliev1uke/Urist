# ============================================================
#  Конфигурация Legal AI Assistant
#  Скопируйте этот файл в .env и заполните значения
#  cp .env.example .env
# ============================================================

# --- PostgreSQL (pgvector) ---
POSTGRES_USER=legal
POSTGRES_PASSWORD=legal_password
POSTGRES_DB=legal_ai
# Используется внутри docker-сети; для локального запуска поменяйте хост на localhost
DATABASE_URL=postgresql+asyncpg://legal:legal_password@db:5432/legal_ai

# --- LLM Provider ---
# Пока выбран stub — возвращает мок-анализ без вызова внешнего API.
# Когда выберете провайдера, укажите: stub | gigachat | openai | yandex
LLM_PROVIDER=stub

# --- GigaChat (Сбер) ---
# Получить ключ: https://developers.sber.ru/ (GigaChat API)
GIGACHAT_API_KEY=
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# --- OpenAI ---
# Получить ключ: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- YandexGPT ---
# https://cloud.yandex.ru/docs/yandexgpt/
YANDEX_API_KEY=
YANDEX_FOLDER_ID=

# --- Embeddings (локальные) ---
# Модель HuggingFace для векторизации русского текста
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# Размерность вектора (для paraphrase-multilingual-MiniLM-L12-v2 = 384)
EMBEDDING_DIM=384

# --- RAG параметры ---
# Сколько релевантных чанков искать в базе знаний для контекста
RAG_TOP_K=8
# Порог косинусного сходства (0..1), ниже которого результаты отбрасываются
RAG_MIN_SIMILARITY=0.3

# --- Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Разрешённые источники для CORS (через запятую)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
